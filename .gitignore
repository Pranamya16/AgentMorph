# Python
__pycache__/
*.py[cod]
*.egg-info/
*.egg
.eggs/
build/
dist/
.pytest_cache/
.coverage
.coverage.*
htmlcov/

# Virtual envs
.venv/
venv/
env/

# IDE / editor
.vscode/
.idea/
*.swp
.DS_Store

# AgentMorph outputs — sweep trajectories, manifests, HF cache mirrors,
# etc. are all runtime artefacts that live on Drive, not in git.
# Exception: runs/paraphrase_cache/ is a COMMITTED asset — it's seeded
# once via scripts/generate_paraphrases.py and the Stage 3 sweep reads
# it in offline mode. So we ignore everything in runs/ EXCEPT that
# subdirectory.
runs/*
!runs/paraphrase_cache/
!runs/paraphrase_cache/**
*.jsonl.tmp
manifest.json.tmp

# Temp files from Word (the plan doc)
~$*.docx

# HF cache if accidentally placed inside repo
hf_cache/
